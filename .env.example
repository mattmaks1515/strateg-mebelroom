# ============================================================
#  ШАБЛОН СЕКРЕТОВ. Скопируй в файл .env и заполни значения.
#  Файл .env в гит НЕ попадает (см. .gitignore).
#  РЕАЛЬНЫЕ значения вписываются ТОЛЬКО на сервере, не в этот файл и не в чат.
# ============================================================

# --- Telegram Bot API ---
# Токен НОВОГО бота от @BotFather (отдельный бот, не тот, что у ПМ-бота).
TELEGRAM_BOT_TOKEN=

# Кому бот отвечает (белый список). Числовые Telegram ID через запятую.
# Владелец и партнёр:
OWNER_USER_ID=419922364,590487361

# --- Anthropic (Claude) ---
# Тот же ключ, что у ПМ-бота.
ANTHROPIC_API_KEY=
# Модель рантайма. Fable 5 — максимум качества рассуждений (то, что нужно советнику).
ANTHROPIC_MODEL=claude-fable-5
# Потолок длины ответа (советник отвечает развёрнуто).
ANTHROPIC_MAX_TOKENS=4096
# Глубина/скорость: low|medium|high|xhigh|max. medium — баланс для чата (быстрее high).
ANTHROPIC_EFFORT=medium
# Таймаут ответа модели, сек. Fable 5 + веб-поиск на сложных вопросах думает минутами.
ANTHROPIC_TIMEOUT=600

# --- Битрикс24 (этап B2) ---
# Формат: https://ВАШ-ПОРТАЛ.bitrix24.ru/rest/USER_ID/КОД_ВЕБХУКА/
# ВНИМАНИЕ: старый вебхук из репозитория ПМ-бота скомпрометирован — используй НОВЫЙ.
BITRIX_WEBHOOK_URL=

# --- Веб-поиск (этап B3) ---
# 1 — включён (по умолчанию), 0 — выключить. Макс. число поисков на один ответ.
WEB_SEARCH=1
WEB_SEARCH_MAX_USES=8

# --- Еженедельный дайджест (этап B4) ---
# 1 — слать дайджест (по умолчанию), 0 — выключить.
SEND_DIGEST=1
# День недели (0=пн … 6=вс) и час рассылки по времени сервера (TZ=Asia/Yekaterinburg).
DIGEST_WEEKDAY=0
DIGEST_HOUR=9
